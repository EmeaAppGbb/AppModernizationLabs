@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="retro-card retro-card-error" style="max-width: 600px; margin: 80px auto;">
    <h3>💀 GAME OVER</h3>
    <p style="margin: 16px 0;">An unexpected error occurred.</p>
    @if (ShowRequestId)
    {
        <p style="font-size: 16px; color: var(--text-secondary);">
            REQUEST ID: @RequestId
        </p>
    }
    <a href="/" class="retro-btn" style="display: inline-block; margin-top: 20px;">↩ CONTINUE?</a>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
