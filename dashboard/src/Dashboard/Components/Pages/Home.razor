@page "/"
@using Dashboard.Services
@using Dashboard.Models
@inject AppInsightsService AppInsights
@rendermode InteractiveServer

<PageTitle>Dashboard Overview</PageTitle>

<div class="dashboard-grid">
    @if (!AppInsights.IsConfigured)
    {
        <div class="retro-card retro-card-warning retro-card-wide">
            <h3 class="card-title">⚠️ APP INSIGHTS NOT CONFIGURED</h3>
            <p>The dashboard cannot query telemetry data. <code>AppInsights:AppId</code> must be set. Auth uses Managed Identity (no API key needed).</p>
            <div class="config-checklist">
                <p>@(AppInsights.HasAppId ? "✅" : "❌") <strong>AppId</strong> — @(AppInsights.HasAppId ? "Present" : "Missing — set via <code>AppInsights__AppId</code> env var")</p>
                <p>🔐 <strong>Auth</strong> — Managed Identity (DefaultAzureCredential)</p>
            </div>
            <div class="config-steps">
                <h4>🔧 HOW TO FIX</h4>
                <ol>
                    <li>Open <strong>Azure Portal</strong> → your Application Insights resource</li>
                    <li>Copy the <strong>Application ID</strong> from the Overview blade</li>
                    <li>Ensure the Container App has a <strong>system-assigned Managed Identity</strong></li>
                    <li>Assign <strong>Monitoring Reader</strong> role on the App Insights resource</li>
                    <li>Set the environment variable: <code>azd env set APP_INSIGHTS_APP_ID &lt;your-app-id&gt;</code></li>
                    <li>Redeploy: <code>azd up</code></li>
                </ol>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="retro-loading">
            <div class="loading-spinner"></div>
            <p>LOADING TELEMETRY DATA...</p>
        </div>
    }
    else if (error is not null)
    {
        <div class="retro-card retro-card-error">
            <h3>⚠️ ERROR</h3>
            <p>@error</p>
            <button class="retro-btn" @onclick="LoadData">RETRY</button>
        </div>
    }
    else
    {
        <!-- Quick Stats Row -->
        <div class="stats-row">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon">👁️</div>
                <div class="stat-value">@FormatNumber(summary?.TotalViewsToday ?? 0)</div>
                <div class="stat-label">VIEWS TODAY</div>
            </div>
            <div class="stat-card stat-card-secondary">
                <div class="stat-icon">📅</div>
                <div class="stat-value">@FormatNumber(summary?.TotalViews7Days ?? 0)</div>
                <div class="stat-label">VIEWS 7 DAYS</div>
            </div>
            <div class="stat-card stat-card-accent">
                <div class="stat-icon">📊</div>
                <div class="stat-value">@FormatNumber(summary?.TotalViews30Days ?? 0)</div>
                <div class="stat-label">VIEWS 30 DAYS</div>
            </div>
            <div class="stat-card stat-card-success">
                <div class="stat-icon">👤</div>
                <div class="stat-value">@FormatNumber(summary?.TotalUniqueUsers ?? 0)</div>
                <div class="stat-label">UNIQUE USERS</div>
            </div>
        </div>

        <!-- Top Labs -->
        <div class="retro-card">
            <h3 class="card-title">🏆 TOP 5 MOST VISITED LABS</h3>
            <div class="retro-table-wrap">
                <table class="retro-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>LAB</th>
                            <th>VIEWS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (summary?.TopPages.Any() == true)
                        {
                            @foreach (var (pv, idx) in summary.TopPages.Take(5).Select((p, i) => (p, i)))
                            {
                                <tr>
                                    <td class="rank-cell">@(idx + 1)</td>
                                    <td>@pv.PageName</td>
                                    <td class="number-cell">@FormatNumber(pv.ViewCount)</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="3" class="empty-cell">No data available — configure App Insights</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Engagement Quick Summary -->
        <div class="retro-card">
            <h3 class="card-title">🎮 ENGAGEMENT SNAPSHOT</h3>
            <div class="engagement-grid">
                <div class="engagement-item">
                    <span class="engagement-value">@FormatNumber(engagement?.TotalCloneClicks ?? 0)</span>
                    <span class="engagement-label">Clone</span>
                </div>
                <div class="engagement-item">
                    <span class="engagement-value">@FormatNumber(engagement?.TotalVsCodeClicks ?? 0)</span>
                    <span class="engagement-label">VS Code</span>
                </div>
                <div class="engagement-item">
                    <span class="engagement-value">@FormatNumber(engagement?.TotalCodespaceClicks ?? 0)</span>
                    <span class="engagement-label">Codespace</span>
                </div>
                <div class="engagement-item">
                    <span class="engagement-value">@FormatNumber(engagement?.TotalStarClicks ?? 0)</span>
                    <span class="engagement-label">Stars</span>
                </div>
            </div>
        </div>

        <!-- Active Users -->
        <div class="retro-card">
            <h3 class="card-title">⚡ ACTIVE NOW</h3>
            <div class="active-users-display">
                <span class="active-count">@(summary?.ActiveUsersNow ?? 0)</span>
                <span class="active-label">users online</span>
                <div class="active-pulse"></div>
            </div>
        </div>
    }
</div>

@code {
    private PageViewSummary? summary;
    private LabEngagementSummary? engagement;
    private bool isLoading = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        error = null;
        StateHasChanged();

        try
        {
            summary = await AppInsights.GetPageViewSummaryAsync();
            engagement = await AppInsights.GetLabEngagementAsync();
        }
        catch (Exception ex)
        {
            error = $"Failed to load dashboard data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string FormatNumber(long value) => value switch
    {
        >= 1_000_000 => $"{value / 1_000_000.0:F1}M",
        >= 1_000 => $"{value / 1_000.0:F1}K",
        _ => value.ToString("N0")
    };
}
