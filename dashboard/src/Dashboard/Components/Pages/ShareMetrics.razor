@page "/shares"
@using Dashboard.Services
@using Dashboard.Models
@inject AppInsightsService AppInsights
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Share Metrics</PageTitle>

<div class="dashboard-grid">
    @if (isLoading)
    {
        <div class="retro-loading">
            <div class="loading-spinner"></div>
            <p>LOADING SHARE DATA...</p>
        </div>
    }
    else
    {
        @if (!AppInsights.IsConfigured)
        {
            <div class="retro-card retro-card-warning retro-card-wide">
                <h3>⚠️ APP INSIGHTS NOT CONFIGURED</h3>
                <p>Share data requires <code>AppInsights:AppId</code> and Managed Identity auth. Visit <a href="status">System Status</a> for setup instructions.</p>
            </div>
        }
        <!-- Stats Row -->
        <div class="stats-row">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon">📤</div>
                <div class="stat-value">@(summary?.TotalShares.ToString("N0") ?? "0")</div>
                <div class="stat-label">TOTAL SHARES</div>
            </div>
            <div class="stat-card stat-card-secondary">
                <div class="stat-icon">🌐</div>
                <div class="stat-value">@(summary?.TotalWebShareApi.ToString("N0") ?? "0")</div>
                <div class="stat-label">WEB SHARE API</div>
            </div>
            <div class="stat-card stat-card-accent">
                <div class="stat-icon">📋</div>
                <div class="stat-value">@(summary?.TotalClipboardCopy.ToString("N0") ?? "0")</div>
                <div class="stat-label">CLIPBOARD COPY</div>
            </div>
            <div class="stat-card stat-card-success">
                <div class="stat-icon">🔗</div>
                <div class="stat-value">@(summary?.SharesByLab.Count.ToString() ?? "0")</div>
                <div class="stat-label">LABS SHARED</div>
            </div>
        </div>

        <!-- Shares Per Lab Chart -->
        <div class="retro-card retro-card-wide">
            <h3 class="card-title">📊 SHARES PER LAB</h3>
            <div class="chart-container">
                <canvas id="sharesPerLabChart"></canvas>
            </div>
        </div>

        <!-- Share Method Breakdown -->
        <div class="retro-card">
            <h3 class="card-title">🔀 SHARE METHOD</h3>
            <div class="chart-container">
                <canvas id="shareMethodChart"></canvas>
            </div>
        </div>

        <!-- Most Shared Labs Table -->
        <div class="retro-card">
            <h3 class="card-title">🏆 MOST SHARED LABS</h3>
            <div class="retro-table-wrap">
                <table class="retro-table">
                    <thead>
                        <tr>
                            <th>LAB</th>
                            <th>SHARES</th>
                            <th>WEB API</th>
                            <th>CLIPBOARD</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (summary?.SharesByLab.Any() == true)
                        {
                            @foreach (var s in summary.SharesByLab)
                            {
                                <tr>
                                    <td>@s.LabName</td>
                                    <td class="number-cell">@s.ShareCount</td>
                                    <td class="number-cell">@s.WebShareApiCount</td>
                                    <td class="number-cell">@s.ClipboardCopyCount</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="empty-cell">No share data available</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Share-to-Visit Conversion -->
        <div class="retro-card retro-card-wide">
            <h3 class="card-title">📈 SHARE → VISIT CONVERSION</h3>
            <div class="retro-table-wrap">
                <table class="retro-table">
                    <thead>
                        <tr>
                            <th>LAB</th>
                            <th>SHARES</th>
                            <th>VISITS</th>
                            <th>CONVERSION</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (summary?.ShareConversions.Any() == true)
                        {
                            @foreach (var c in summary.ShareConversions)
                            {
                                <tr>
                                    <td>@c.LabName</td>
                                    <td class="number-cell">@c.Shares</td>
                                    <td class="number-cell">@c.ResultingVisits</td>
                                    <td class="number-cell conversion-rate">@c.ConversionRate.ToString("F1")%</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="empty-cell">No conversion data available</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private ShareMetricSummary? summary;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            summary = await AppInsights.GetShareMetricsAsync();
        }
        catch { }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || summary is null) return;

        var labNames = summary.SharesByLab.Select(s => s.LabName).ToArray();
        var shares = summary.SharesByLab.Select(s => s.ShareCount).ToArray();
        await JS.InvokeVoidAsync("RetroCharts.createBarChart", "sharesPerLabChart", labNames, shares, "Shares");

        await JS.InvokeVoidAsync("RetroCharts.createDoughnutChart", "shareMethodChart",
            new[] { "Web Share API", "Clipboard Copy" },
            new[] { summary.TotalWebShareApi, summary.TotalClipboardCopy },
            "Share Methods");
    }
}
