@page "/status"
@using Dashboard.Services
@inject AppInsightsService AppInsights
@inject YouTubeAnalyticsService YouTube
@rendermode InteractiveServer

<PageTitle>System Status</PageTitle>

<div class="dashboard-grid">
    <div class="retro-card retro-card-wide">
        <h3 class="card-title">🔧 CONFIGURATION STATUS</h3>
        <div class="retro-table-wrap">
            <table class="retro-table">
                <thead>
                    <tr>
                        <th>SERVICE</th>
                        <th>STATUS</th>
                        <th>DETAILS</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>App Insights — AppId</td>
                        <td class="@(AppInsights.HasAppId ? "status-ok" : "status-fail")">
                            @(AppInsights.HasAppId ? "✅ SET" : "❌ MISSING")
                        </td>
                        <td>Environment variable: <code>AppInsights__AppId</code></td>
                    </tr>
                    <tr>
                        <td>App Insights — Auth</td>
                        <td class="status-ok">🔐 MANAGED IDENTITY</td>
                        <td>Uses <code>DefaultAzureCredential</code> (Managed Identity → Azure CLI → VS Code fallback)</td>
                    </tr>
                    <tr>
                        <td>App Insights — Token</td>
                        <td class="@(tokenTestResult.HasValue ? (tokenTestResult.Value.Success ? "status-ok" : "status-fail") : "status-warn")">
                            @if (tokenTestResult.HasValue)
                            {
                                @(tokenTestResult.Value.Success ? "✅ ACQUIRED" : "❌ FAILED")
                            }
                            else
                            {
                                <span>⏳ NOT TESTED</span>
                            }
                        </td>
                        <td>
                            @if (tokenTestResult.HasValue)
                            {
                                @tokenTestResult.Value.Message
                            }
                            else
                            {
                                <span>Run connection test below to verify token acquisition</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td>App Insights — Overall</td>
                        <td class="@(AppInsights.IsConfigured ? "status-ok" : "status-fail")">
                            @(AppInsights.IsConfigured ? "✅ READY" : "❌ NOT CONFIGURED")
                        </td>
                        <td>AppId required; auth via Managed Identity</td>
                    </tr>
                    <tr>
                        <td>YouTube API</td>
                        <td class="@(YouTube.IsConfigured ? "status-ok" : "status-warn")">
                            @(YouTube.IsConfigured ? "✅ SET" : "⚠️ OPTIONAL — NOT SET")
                        </td>
                        <td>Environment variable: <code>YouTube__ApiKey</code></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="retro-card retro-card-wide">
        <h3 class="card-title">🧪 CONNECTION TEST</h3>
        @if (isTesting)
        {
            <div class="retro-loading">
                <div class="loading-spinner"></div>
                <p>RUNNING TEST QUERY...</p>
            </div>
        }
        else if (testResult.HasValue)
        {
            <div class="retro-table-wrap">
                <table class="retro-table">
                    <thead>
                        <tr>
                            <th>TEST</th>
                            <th>RESULT</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Azure AD Token</td>
                            <td class="@(tokenTestResult?.Success == true ? "status-ok" : "status-fail")">
                                @if (tokenTestResult?.Success == true)
                                {
                                    <span>✅ @tokenTestResult.Value.Message</span>
                                }
                                else
                                {
                                    <span>❌ @(tokenTestResult?.Message ?? "Token not acquired")</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td>Page views (last 7 days)</td>
                            <td class="@(testResult.Value >= 0 ? "status-ok" : "status-fail")">
                                @if (testResult.Value >= 0)
                                {
                                    <span>✅ @testResult.Value.ToString("N0") page views</span>
                                }
                                else
                                {
                                    <span>❌ Query failed — check AppId and Managed Identity permissions</span>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p>Click the button below to test the App Insights API connection via Managed Identity.</p>
        }
        <button class="retro-btn" @onclick="RunTest" disabled="@(!AppInsights.IsConfigured || isTesting)">
            @(AppInsights.IsConfigured ? "RUN TEST QUERY" : "CONFIGURE APP INSIGHTS FIRST")
        </button>
    </div>

    @if (!AppInsights.IsConfigured)
    {
        <div class="retro-card retro-card-warning retro-card-wide">
            <h3 class="card-title">📋 SETUP GUIDE</h3>
            <div class="config-steps">
                <ol>
                    <li>Open <strong>Azure Portal</strong> → your Application Insights resource</li>
                    <li>Find the <strong>Application ID</strong> on the Overview blade (or API Access page) — this is the AppId</li>
                    <li>Ensure the Container App has a <strong>system-assigned Managed Identity</strong> enabled</li>
                    <li>Assign the <strong>Monitoring Reader</strong> role on the App Insights resource to the Managed Identity</li>
                    <li>Set the AppId environment variable:
                        <pre>azd env set APP_INSIGHTS_APP_ID &lt;your-app-id&gt;</pre>
                    </li>
                    <li>Redeploy: <code>azd up</code></li>
                </ol>
                <p><em>No API key needed — authentication is handled by Managed Identity.</em></p>
            </div>
        </div>
    }
</div>

@code {
    private bool isTesting;
    private long? testResult;
    private (bool Success, string Message)? tokenTestResult;

    private async Task RunTest()
    {
        isTesting = true;
        StateHasChanged();

        try
        {
            tokenTestResult = await AppInsights.TestTokenAcquisitionAsync();
            testResult = await AppInsights.TestConnectionAsync();
        }
        finally
        {
            isTesting = false;
        }
    }
}
